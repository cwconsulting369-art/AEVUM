# AEVUM Portal — Environment Variables
# Copy to .env.local for local dev, set in Vercel for production

# API base URL (AEVUM backend) — Portal nutzt VITE_AEVUM_API_BASE_URL (siehe lib/api.ts + components/agent/ProjectAgentChat.tsx)
VITE_AEVUM_API_BASE_URL=http://localhost:3210

# Telegram Bot Username for the login deep-link
# Set to your actual bot username in Vercel (without the @)
VITE_AEVUM_BOT_USERNAME=AEVUMBusinessBot
