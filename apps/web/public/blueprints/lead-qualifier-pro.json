      "main": [[{ "node": "Format Response", "type": "main", "index": 0 }]]
    },
    "Push to CRM (Airtable) — Warm/Cold": {
      "main": [[{ "node": "Format Response", "type": "main", "index": 0 }]]
    },
    "Format Response": {
      "main": [[{ "node": "Respond to Webhook", "type": "main", "index": 0 }]]
    }
  },
  "active": false,
  "settings": {
