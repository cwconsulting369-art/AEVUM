  "versionId": "v1.0.0",
  "id": "aevum-lead-qualifier-pro",
  "meta": {
    "templateCredsSetupCompleted": false,
    "aevum_version": "1.0.0",
    "aevum_description": "BANT-Scoring + CRM-Push + Sales-Notification. DSGVO-konform bei EU-Hosting des n8n + EU-Airtable-Workspace.",
    "aevum_required_credentials": ["Anthropic API", "Airtable Personal Access Token", "SMTP / Email-Send"],
    "aevum_setup_steps": [
      "1. Anthropic-API-Key in n8n Credentials anlegen",
      "2. Airtable-PAT mit Schema-Write-Access erstellen",
      "3. Airtable-Base anlegen mit Tabelle 'Leads' + Felder: Name, Email, Company, BANT Score, Priority, Reasoning, Next Action, Qualified At",
      "4. PLACEHOLDER_BASE in beiden CRM-Push-Nodes durch deine Airtable-Base-ID ersetzen",
      "5. SMTP-Credentials für Sales-Team-Email konfigurieren",
      "6. Webhook URL aus dem Trigger-Node in dein Lead-Form einbauen",
      "7. Test-Submit auf den Webhook → prüfe Airtable + Sales-Email"
    ]
  },
  "tags": ["aevum", "blueprint", "leads", "qualifier", "dsgvo"]
}
