        "message": "=<h2>Neuer Hot Lead eingegangen</h2>\n<p><strong>Name:</strong> {{ $json.firstName }} {{ $json.lastName }}</p>\n<p><strong>Unternehmen:</strong> {{ $json.company }}</p>\n<p><strong>E-Mail:</strong> {{ $json.email }}</p>\n<p><strong>Score:</strong> {{ $json.score }}/100</p>\n<p><strong>Eingegangen:</strong> {{ $json.submittedAt }}</p>\n<hr>\n<h3>Score-Aufschlüsselung</h3>\n<ul>\n<li>Budget: {{ $json.scoreBreakdown.budget }}/25</li>\n<li>Entscheidungsbefugnis: {{ $json.scoreBreakdown.authority }}/20</li>\n<li>Bedarf: {{ $json.scoreBreakdown.need }}/20</li>\n<li>Timing: {{ $json.scoreBreakdown.timing }}/15</li>\n<li>Unternehmensgröße: {{ $json.scoreBreakdown.companySize }}/10</li>\n<li>Branche: {{ $json.scoreBreakdown.industry }}/5</li>\n<li>Engagement: {{ $json.scoreBreakdown.engagement }}/5</li>\n</ul>\n<hr>\n<h3>Nachricht</h3>\n<p>{{ $json.message }}</p>\n<p><strong>Empfehlung: Innerhalb von 2 Stunden zurückrufen/melden.</strong></p>",
