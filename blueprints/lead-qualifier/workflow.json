    {
      "parameters": {
        "language": "javaScript",
        "jsCode": "// AEVUM Lead Qualifier — BANT+ Scoring Engine\n// Anpassen: weights, thresholds, targetIndustries\n\nconst lead = items[0].json;\n\n// === KONFIGURATION ===\nconst weights = {\n  budget: 25,\n  authority: 20,\n  need: 20,\n  timing: 15,\n  companySize: 10,\n  industry: 5,\n  engagement: 5\n};\n\nconst thresholds = {\n  hot: 70,\n  warm: 40\n};\n\n// Deine Ziel-Branchen (lowercase)\nconst targetIndustries = [\n  'immobilien', 'hausverwaltung', 'makler', 'real estate',\n  'agentur', 'marketing', 'beratung', 'consulting',\n  'dienstleistung', 'ecommerce', 'e-commerce'\n];\n\n// === SCORING LOGIK ===\n\n// 1. Budget (0 / 50% / 100% der Gewichtung)\nlet budgetScore = 0;\nconst b = lead.budget?.toLowerCase() || '';\nif (b.includes('5000') || b.includes('15000') || b.includes('5.000') || b.includes('15.000')) {\n  budgetScore = Math.round(weights.budget * 0.5);\n} else if (b.includes('15') || b.includes('>') || b.includes('gross') || b.includes('groß')) {\n  budgetScore = weights.budget;\n}\n\n// 2. Authority (Entscheider-Rolle)\nlet authorityScore = 0;\nconst r = lead.role?.toLowerCase() || '';\nif (r.includes('geschäftsführer') || r.includes('gf') || r.includes('ceo') || r.includes('inhaber') || r.includes('owner') || r.includes('founder')) {\n  authorityScore = weights.authority;\n} else if (r.includes('manager') || r.includes('leiter') || r.includes('head') || r.includes('direktor')) {\n  authorityScore = Math.round(weights.authority * 0.5);\n}\n\n// 3. Need (Nachricht-Analyse)\nlet needScore = 0;\nconst msg = lead.message?.toLowerCase() || '';\nconst urgentKeywords = ['sofort', 'dringend', 'asap', 'problem', 'verlieren', 'fehlt', 'broken', 'funktioniert nicht', 'chaos'];\nconst concreteKeywords = ['automatisierung', 'prozess', 'workflow', 'system', 'effizienz', 'skalierung', 'wachstum', 'leads', 'umsatz'];\nif (urgentKeywords.some(k => msg.includes(k))) {\n  needScore = weights.need;\n} else if (concreteKeywords.some(k => msg.includes(k)) || msg.length > 100) {\n  needScore = Math.round(weights.need * 0.6);\n} else if (msg.length > 30) {\n  needScore = Math.round(weights.need * 0.3);\n}\n\n// 4. Timing\nlet timingScore = 0;\nconst t = lead.timing?.toLowerCase() || '';\nif (t.includes('sofort') || t.includes('diesen monat') || t.includes('1 monat') || t.includes('<3') || t.includes('asap')) {\n  timingScore = weights.timing;\n} else if (t.includes('3 monate') || t.includes('quartal') || t.includes('bald')) {\n  timingScore = Math.round(weights.timing * 0.5);\n}\n\n// 5. Unternehmensgröße\nlet companySizeScore = 0;\nconst cs = lead.companySize?.toLowerCase() || '';\nif (cs.includes('>50') || cs.includes('50+') || cs.includes('100') || cs.includes('mittelstand') || cs.includes('enterprise')) {\n  companySizeScore = weights.companySize;\n} else if (cs.includes('10') || cs.includes('20') || cs.includes('30') || cs.includes('40') || cs.includes('kmu')) {\n  companySizeScore = Math.round(weights.companySize * 0.5);\n}\n\n// 6. Branche\nlet industryScore = 0;\nconst ind = lead.industry?.toLowerCase() || '';\nif (targetIndustries.some(i => ind.includes(i))) {\n  industryScore = weights.industry;\n}\n\n// 7. Engagement / Source\nlet engagementScore = 0;\nconst src = lead.source?.toLowerCase() || '';\nif (src.includes('empfehlung') || src.includes('referral') || src.includes('weiterempfehlung')) {\n  engagementScore = weights.engagement;\n} else if (src.includes('linkedin') || src.includes('instagram') || src.includes('google')) {\n  engagementScore = Math.round(weights.engagement * 0.4);\n}\n\n// === GESAMTSCORE ===\nconst totalScore = budgetScore + authorityScore + needScore + timingScore + companySizeScore + industryScore + engagementScore;\n\n// Routing bestimmen\nlet routing = 'cold';\nlet priority = 'niedrig';\nif (totalScore >= thresholds.hot) {\n  routing = 'hot';\n  priority = 'hoch';\n} else if (totalScore >= thresholds.warm) {\n  routing = 'warm';\n  priority = 'mittel';\n}\n\nreturn [{\n  json: {\n    ...lead,\n    score: totalScore,\n    routing: routing,\n    priority: priority,\n    scoreBreakdown: {\n      budget: budgetScore,\n      authority: authorityScore,\n      need: needScore,\n      timing: timingScore,\n      companySize: companySizeScore,\n      industry: industryScore,\n      engagement: engagementScore\n    }\n  }\n}];"
      },
      "id": "code-bant-scoring",
      "name": "Code: BANT Scoring",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 300]
    },
